<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="600.0" spacing="10" style="-fx-background-color: #CCFFFF;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.example.laba1_shelgerman.ConverterController">

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold;"  text="Конвертер рабочего времени" />

    <TextField fx:id="inputField" maxHeight="Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="220"  promptText="Введите значение" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

    <ComboBox fx:id="fromComboBox" prefWidth="220" />

    <ComboBox fx:id="toComboBox" prefWidth="220" />

    <Button fx:id="convertButton" onAction="#handleConvert" text="Конвертировать" />

    <Label fx:id="resultLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="25.0" prefWidth="504.0" style="-fx-text-fill: green;              -fx-font-size: 16px;               -fx-font-weight: bold;" textAlignment="JUSTIFY" />

    <Label fx:id="errorLabel" alignment="CENTER" contentDisplay="CENTER" prefHeight="17.0" prefWidth="476.0" style="-fx-text-fill: red;" textAlignment="JUSTIFY" />

</VBox>
